# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code session state
.claude/

# Superpowers workflow docs (specs/plans/progress) — kept local, not versioned
docs/superpowers/

# Bundle outputs (rpm/deb/appimage are uploaded as GitHub release
# assets, not committed). Cargo target + Tauri gen are ignored
# already by src-tauri/.gitignore but listed here for safety.
src-tauri/target/
src-tauri/gen/
*.rpm
*.deb
*.AppImage

# Local secrets — keyring is the source of truth, but block stray dumps
.env
.env.*
*.token
